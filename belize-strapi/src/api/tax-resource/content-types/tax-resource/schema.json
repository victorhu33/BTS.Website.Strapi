{
  "kind": "collectionType",
  "collectionName": "tax_resources",
  "info": {
    "singularName": "tax-resource",
    "pluralName": "tax-resources",
    "displayName": "Tax_Resource"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "tax_resource_categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tax-resource-category.tax-resource-category",
      "inversedBy": "Tax_Resources"
    },
    "Tax_Resource_Title": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "Tax_Resource_ID": {
      "type": "uid",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "targetField": "Tax_Resource_Title"
    },
    "Tax_Resource_Body": {
      "type": "blocks",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "Tax_Resource_Attachments": {
      "type": "media",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "Tax_Resource_Effective_Date": {
      "type": "date",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "Tax_Resource_Type": {
      "type": "enumeration",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "enum": [
        "Legal",
        "Publication",
        "Forms & Downloads",
        "Tax Ruling",
        "Guidelines",
        "ACT"
      ]
    },
    "Tax_Resource_Summary": {
      "type": "blocks",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "Tax_Resurce_Url": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "Tax_Resource_Tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag",
      "mappedBy": "tax_resources"
    }
  }
}
